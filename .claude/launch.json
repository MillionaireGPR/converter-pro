{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite + React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8080,
      "autoPort": true
    },
    {
      "name": "Backend (FastAPI image extractor)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd backend\\image_extractor && python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload"],
      "port": 8000
    }
  ]
}
