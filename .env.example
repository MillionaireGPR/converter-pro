# ============================================
# Variaveis de ambiente - Converter Pro
# Copie este arquivo para .env.local e preencha
# ============================================

# --- Frontend (Vite/Vercel) ---
# URL do backend Python apos deploy no Render
# Local: http://localhost:8000
# Producao: https://<nome-do-servico>.onrender.com
VITE_BACKEND_URL=http://localhost:8000

# --- Backend (Python/Render) ---
# Configurado direto no Render Dashboard, nao em arquivo
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
